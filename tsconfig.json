{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "dist",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "skipLibCheck": true,
        "strict": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "allowJs": true
    },
    "include": [
        "./",
        "./**/*.ts",
        "./**/*.js",
        "src/**/*.json",
        "src/**/*",
        "config/**/*",
        ".env",
        "types/**/*"
    ],
    "exclude": [
        "node_modules",
        "build",
        "dist",
        ".cache",
        ".tmp",
        "frontend"
    ]
}